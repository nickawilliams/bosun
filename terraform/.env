# Terraform provider
TF_VAR_github_token="${GITHUB_TOKEN}"

# Secrets (terraform provisions these to GitHub Actions secrets)
TF_VAR_github_bot_token="${BOT_TOKEN}"
TF_VAR_gpg_private_key="${GPG_PRIVATE_KEY}"
TF_VAR_codecov_token="${CODECOV_TOKEN}"
TF_VAR_homebrew_token="${HOMEBREW_TOKEN}"
TF_VAR_macports_token="${MACPORTS_TOKEN}"

# Config (terraform provisions these to GitHub Actions variables;
# also used directly by the Makefile via ?= defaults)
TF_VAR_homebrew_repo="${HOMEBREW_REPO}"
TF_VAR_macports_repo="${MACPORTS_REPO}"
TF_VAR_macports_pullrequest="${MACPORTS_PULLREQUEST}"
