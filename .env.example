# Terraform GitHub Token (your personal PAT with repo + admin:org scopes)
GITHUB_TOKEN=""

# CI GitHub Tokens
BOT_TOKEN=""
HOMEBREW_TOKEN="$BOT_TOKEN"
MACPORTS_TOKEN="$BOT_TOKEN"

# Git Commit Signing (should match CI bot account)
GPG_PRIVATE_KEY=""

# Codecov Token (for coverage reporting)
CODECOV_TOKEN=""

# Terraform variable mappings (reference the variables above so
# `source .env && terraform apply` just works)
TF_VAR_github_token="$GITHUB_TOKEN"
TF_VAR_github_bot_token="$BOT_TOKEN"
TF_VAR_gpg_private_key="$GPG_PRIVATE_KEY"
TF_VAR_codecov_token="$CODECOV_TOKEN"
TF_VAR_homebrew_token="$HOMEBREW_TOKEN"
TF_VAR_macports_token="$MACPORTS_TOKEN"
